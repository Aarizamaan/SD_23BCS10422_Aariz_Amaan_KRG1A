        <mxCell id="kRsG7KTjLfMX7tFLOnpQ-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Functional Requirements&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;1. User should be able to login and signup&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2.user should be able to search the products&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;3. Product catalog&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;4.cart service&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;5.order status service&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;6.checkout service&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Non functional requirements:&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1. should be able to handle 1.5 DAU&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2. High availabilty is required&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;3. Strong consistency for payments and inventory management&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;API DESIGN:&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;U&lt;span style=&quot;background-color: transparent;&quot;&gt;Auth Service&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;POST /signup&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;POST /login&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Product Service&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;GET /products&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;GET /products/{id}&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Search Service&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;GET /search?q=...&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Cart Service&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;GET /cart&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;POST /cart/items&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Order Service&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;POST /checkout&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;GET /orders/{id}&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;DATA BASE DESIGN:&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;div style=&quot;&quot;&gt;USER&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; │&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; ├── CART&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; │&amp;nbsp; &amp;nbsp; &amp;nbsp;└── CART_ITEMS ── PRODUCT&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; │&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; └── ORDERS&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; └── ORDER_ITEMS ── PRODUCT&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;PRODUCT ── CATEGORY&lt;/div&gt;&lt;div style=&quot;&quot;&gt;ORDERS ── PAYMENTS&lt;/div&gt;&lt;div style=&quot;&quot;&gt;ORDERS ── ORDER_STATUS_HISTORY&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
